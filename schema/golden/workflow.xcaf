kind: workflow
version: "1.0"
name: golden-workflow
description: "Reference workflow exercising every WorkflowConfig field."

steps:
  - name: plan
    description: "Analyze the task and produce a plan."
    skill: planning-skill

  - name: implement
    description: "Execute the plan."
    skill: implementation-skill

  - name: verify
    description: "Verify correctness."
    skill: verification-skill

  - name: review
    description: "Final review before completion."
    instructions: |
      Review all changes for quality and completeness.
      Ensure tests pass and documentation is updated.
      Sign off on the implementation.

activation: always

artifacts:
  - docs
  - examples

targets:
  claude:
    suppress-fidelity-warnings: false
    skip-synthesis: false
    provider:
      lowering-strategy: rule-plus-skill
  antigravity:
    suppress-fidelity-warnings: true
    skip-synthesis: true
